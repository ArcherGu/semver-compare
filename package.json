{
  "name": "semver-compare",
  "version": "0.0.1",
  "description": "A GitHub Action to compare semver versions",
  "author": "ArcherGu",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/ArcherGu/semver-compare.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@lightwing/eslint-config": "^1.0.151",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json,yml}": [
      "eslint --fix"
    ]
  }
}
